{
  "services": [
    {
      "type": "Independent",
      "name": "main",
      "handler-deps": [
        {
          "name": "public-api",
          "proxies": [
            "auth_proxy",
            "audit_proxy"
          ]
        }
      ],
      "handlers": [
        {
          "type": "Replier",
          "category": "main",
          "endpoint": {
            "id": "localhost",
            "port": 4101
          }
        }
      ]
    },
    {
      "type": "Proxy",
      "name": "auth_proxy",
      "handlers": [
        {
          "type": "Replier",
          "category": "auth-proxy",
          "endpoint": {
            "id": "localhost",
            "port": 4201
          },
          "command-deps": [
            {
              "name": "authorize",
              "proxies": [
                "audit_proxy"
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Proxy",
      "name": "audit_proxy",
      "handlers": [
        {
          "type": "Replier",
          "category": "audit-proxy",
          "endpoint": {
            "id": "audit_1",
            "port": 4301
          },
          "command-deps": [
            {
              "name": "record-audit",
              "extensions": [
                "user_service"
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Independent",
      "name": "user_service",
      "handlers": [
        {
          "type": "Replier",
          "category": "user-service",
          "endpoint": {
            "id": "user_api_1",
            "port": 4401
          }
        }
      ]
    }
  ]
}
