{
  "services": [
    {
      "type": "Independent",
      "name": "dep_target_catalog",
      "handlers": [
        {
          "type": "Replier",
          "category": "catalog",
          "endpoint": {
            "id": "catalog_1",
            "port": 4999
          },
          "command-deps": [
            {
              "name": "all-target-forms",
              "proxies": [
                "pkg:$?var=services[name:auth_proxy]&category=auth-proxy"
              ],
              "extensions": [
                "pkg:$?var=services[name:user_service]&category=user-service"
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Independent",
      "name": "main",
      "handler-deps": [
        {
          "name": "public-api",
          "proxies": [
            "pkg:$?var=services[name:auth_proxy]&category=auth-proxy"
          ]
        }
      ],
      "handlers": [
        {
          "type": "Replier",
          "category": "main",
          "endpoint": {
            "id": "localhost",
            "port": 4101
          },
          "command-deps": [
            {
              "name": "authorize",
              "proxies": [
                "pkg:$?var=services[name:auth_proxy]&category=auth-proxy"
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Proxy",
      "name": "auth_proxy",
      "handlers": [
        {
          "type": "Replier",
          "category": "auth-proxy",
          "endpoint": {
            "id": "localhost",
            "port": 4201
          },
          "outbounds": [],
          "command-deps": [
            {
              "name": "authorize",
              "proxies": [
                "pkg:$?var=services[name:audit_proxy]&category=audit-proxy"
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Proxy",
      "name": "audit_proxy",
      "handlers": [
        {
          "type": "Replier",
          "category": "audit-proxy",
          "endpoint": {
            "id": "audit_1",
            "port": 4301
          },
          "outbounds": [],
          "command-deps": [
            {
              "name": "record-audit",
              "extensions": [
                "pkg:$?var=services[name:user_service]&category=user-service"
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Independent",
      "name": "user_service",
      "handlers": [
        {
          "type": "Replier",
          "category": "user-service",
          "endpoint": {
            "id": "user_api_1",
            "port": 4401
          }
        }
      ]
    }
  ]
}
